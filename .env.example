# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://user:password@host:5432/duedev

# GitHub OAuth
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Optional. Raises the public preview scanner rate limit.
GITHUB_TOKEN=github_pat_replace

# AI analysis
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
# Optional. When omitted, checkout creates inline Stripe price data from the app amounts.
STRIPE_SELLER_PRICE_ID=price_replace
STRIPE_BUYER_PRICE_ID=price_replace
STRIPE_MONITOR_PRICE_ID=price_replace
